{
  "name": "keepnotes-desktop",
  "productName": "KeepNotes",
  "version": "1.0.1",
  "description": "A simple, secure sticky-notes and checklist desktop app that stores everything as plain .txt files.",
  "main": "main.js",
  "author": "MooCalf",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "icons": "node scripts/sync-icons.js"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "lucide-static": "^1.24.0"
  },
  "build": {
    "appId": "com.moocalf.keepnotes",
    "productName": "KeepNotes",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "KeepNotes-Setup-${version}.exe"
    }
  }
}
